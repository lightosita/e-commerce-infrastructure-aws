# --- NGINX Ingress Controller ---
# Implements Layer 7 (HTTP/HTTPS) traffic routing inside the EKS cluster
# Provisions an AWS Network Load Balancer for external traffic ingress
# Routes requests to microservices based on hostname and URL path rules
resource "helm_release" "nginx_ingress" {
  name             = "ingress-nginx"
  repository       = "https://kubernetes.github.io/ingress-nginx"
  chart            = "ingress-nginx"
  version          = "4.9.0"
  namespace        = "ingress-nginx"
  create_namespace = true

  set {
    name  = "controller.service.type"
    value = "LoadBalancer"
  }

  set {
    name  = "controller.service.annotations.service\\.beta\\.kubernetes\\.io/aws-load-balancer-type"
    value = "nlb"
  }

  depends_on = [module.eks]
}
